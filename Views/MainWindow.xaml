<Window
    x:Class="ContestMonitor.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:v="clr-namespace:ContestMonitor.Views"
    Title="Contest Monitor"
    Width="640" Height="720"
    MinWidth="520" MinHeight="560"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource BgBrush}"
    TextOptions.TextFormattingMode="Ideal"
    FontFamily="Segoe UI"
    Activated="OnActivated">

    <Window.Resources>
        <v:StatusBrushConverter x:Key="StatusBrush" />
        <v:BoolToVisibilityConverter x:Key="BoolVis" />
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===================== Header ===================== -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Path Style="{StaticResource Icon}" Width="22" Height="22"
                      Stroke="{StaticResource AccentBrush}"
                      Data="{StaticResource Icon.Trophy}" />
            </Border>

            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Contest Monitor" Style="{StaticResource H1}" />
                <TextBlock Text="Red de Programación Competitiva" Style="{StaticResource Caption}" />
            </StackPanel>

            <!-- Status pill -->
            <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="20"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Padding="12,6">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding StatusKind, Converter={StaticResource StatusBrush}}" />
                    <TextBlock Text="{Binding StatusText}" Margin="8,0,0,0"
                               VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource TextBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Schedule card ===================== -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Path Style="{StaticResource Icon}" Stroke="{StaticResource MutedBrush}"
                          Data="{StaticResource Icon.Clock}" VerticalAlignment="Center" />
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="Last check" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding LastCheck}" Foreground="{StaticResource TextBrush}"
                                   FontSize="14" FontWeight="Medium" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Path Style="{StaticResource Icon}" Stroke="{StaticResource MutedBrush}"
                          Data="{StaticResource Icon.Calendar}" VerticalAlignment="Center" />
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="Next check" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding NextCheck}" Foreground="{StaticResource TextBrush}"
                                   FontSize="14" FontWeight="Medium" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== Actions ===================== -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Style="{StaticResource PrimaryButton}"
                    Command="{Binding CheckNowCommand}" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource Icon}" Width="16" Height="16"
                          Stroke="#0E1015" Data="{StaticResource Icon.Refresh}" />
                    <TextBlock Text="Check now" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                    Command="{Binding MarkSeenCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource Icon}" Width="16" Height="16"
                          Stroke="{StaticResource SuccessBrush}" Data="{StaticResource Icon.Check}" />
                    <TextBlock Text="Mark as seen" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- New-contest counter badge -->
            <Border Grid.Column="3" VerticalAlignment="Center" CornerRadius="20"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource AlertBrush}" BorderThickness="1"
                    Padding="12,6"
                    Visibility="{Binding HasAlert, Converter={StaticResource BoolVis}}">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource Icon}" Width="15" Height="15"
                          Stroke="{StaticResource AlertBrush}" Data="{StaticResource Icon.Bell}" />
                    <TextBlock Text="{Binding NewCount}" Margin="8,0,4,0" VerticalAlignment="Center"
                               Foreground="{StaticResource AlertBrush}" FontWeight="SemiBold" />
                    <TextBlock Text="new" VerticalAlignment="Center"
                               Foreground="{StaticResource AlertBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Contest list ===================== -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="6">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Contests}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="4,3" CornerRadius="9"
                                        Background="{StaticResource SurfaceAltBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="8" Height="8"
                                                 VerticalAlignment="Center" Margin="2,0,10,0"
                                                 Fill="{StaticResource AlertBrush}"
                                                 Visibility="{Binding IsNew, Converter={StaticResource BoolVis}}" />

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                                       FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <Path Style="{StaticResource Icon}" Width="13" Height="13"
                                                      Stroke="{StaticResource MutedBrush}"
                                                      Data="{StaticResource Icon.Clock}" />
                                                <TextBlock Text="{Binding Start}" Style="{StaticResource Caption}"
                                                           Margin="6,0,0,0" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="Registration ends" Style="{StaticResource Caption}"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding RegistrationEnd}" Foreground="{StaticResource TextBrush}"
                                                       FontSize="12" Margin="0,2,0,0" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <TextBlock Text="No upcoming contests yet" Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="13"
                           Visibility="{Binding IsListEmpty, Converter={StaticResource BoolVis}}" />
            </Grid>
        </Border>

        <!-- ===================== Settings footer ===================== -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,14,0">
                    <TextBlock Text="Daily check times" Foreground="{StaticResource TextBrush}"
                               FontSize="13" FontWeight="Medium" />
                    <TextBlock Text="24h, comma-separated" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                </StackPanel>

                <TextBox Grid.Column="1" Style="{StaticResource Field}" VerticalAlignment="Center"
                         Text="{Binding CheckTimesText, UpdateSourceTrigger=PropertyChanged}" />

                <Button Grid.Column="2" Style="{StaticResource GhostButton}" Margin="10,0,0,0"
                        Command="{Binding SaveTimesCommand}" Content="Save" />
            </Grid>
        </Border>
    </Grid>
</Window>
